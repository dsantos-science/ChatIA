#!/bin/bash
PATTERNS="AIza[0-9A-Za-z_-]{35}|sk-[a-zA-Z0-9]{48}|ghp_[a-zA-Z0-9]{36}"
FILES=$(git diff --cached --name-only --diff-filter=ACM)
[ -z "$FILES" ] && exit 0
for FILE in $FILES; do
    if grep -qE "$PATTERNS" "$FILE" 2>/dev/null; then
        echo "BLOQUEADO: Possivel API key em: $FILE — remova antes de commitar."
        exit 1
    fi
done
exit 0
